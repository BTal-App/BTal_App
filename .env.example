# Firebase Web App config
# Copia este archivo a .env y rellena con los valores reales
# Console Firebase → Project Settings → tu Web App → SDK setup and configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase Analytics web (Fase 13-2) · forever-free unlimited.
# Activar en Firebase Console → Analytics (menú izquierdo) → Habilitar
# Google Analytics. Luego Project Settings → tu Web App → buscar
# "Measurement ID" (formato G-XXXXXXXX). Público, embebido en bundle
# igual que las VITE_FIREBASE_* keys.
# Sin esto, Analytics web no inicializa · la app sigue funcionando · el
# banner cookies sigue saliendo. En Fase 9 el SDK nativo
# `@capacitor-firebase/analytics` reportará al mismo proyecto Firebase
# usando GoogleService-Info.plist (iOS) y google-services.json (Android).
VITE_FIREBASE_MEASUREMENT_ID=

# App Check · reCAPTCHA Enterprise site key (PUBLIC, va embebido en el
# bundle). Reemplaza al viejo VITE_RECAPTCHA_V3_SITE_KEY (Classic v3,
# free tier 10K/mes, scoring frágil con Brave Shields/incógnito).
#
# Enterprise es free tier 1M/mes y mucho más estable en entornos no-
# browser puro. Obtener en:
#   Google Cloud Console > Security > reCAPTCHA Enterprise > Create key
#   Tipo: "Score-based" · WAF: no · Domain list: btal-app.web.app +
#   localhost (para dev local con npm run dev)
# Luego registrar el site key en Firebase Console > App Check > Apps >
# tu web app > toggle "reCAPTCHA Enterprise" > pegar la key.
#
# Sin esta variable, App Check web NO se inicializa y las llamadas pasan
# sin token · si Firebase Console está en modo enforcement, las llamadas
# fallarán 403. En Capacitor nativo NO se usa esta key · ahí se usa
# Play Integrity (Android) / DeviceCheck (iOS) via plugin Capacitor.
VITE_RECAPTCHA_ENTERPRISE_SITE_KEY=

# App Check DEBUG mode (DEV ONLY) · activa solo si estás testeando en
# Capacitor Android/iOS WebView o algún navegador donde reCAPTCHA v3
# Classic puntúa bajo y App Check rechaza con 403 (Brave Shields,
# incógnito, emulador). Al activar `true`, el SDK imprime un UUID en
# console (DevTools / chrome://inspect) que debes registrar UNA VEZ en:
#   Firebase Console > App Check > Apps > tu app > Manage debug tokens
# Solo afecta a TU device con ese UUID · otros users siguen pasando
# por reCAPTCHA normal. Quitar (`false` o borrar la línea) antes de
# cada release a Play Store / App Store · sino los users reales serán
# rechazados con 403. La forma canónica en BTal es tenerla en .env.local
# (que está gitignored) solo para dev y no en .env (que es el "release").
VITE_APPCHECK_DEBUG=

# Gemini API key (Fase 6 IA). NO es para el bundle del cliente.
# Solo se usa desde Cloud Functions vía Firebase Functions secrets:
# `firebase functions:secrets:set GEMINI_API_KEY`. Conservada aquí para
# dev local del backend mientras se construye Fase 6. NUNCA committear.
# Obtener en https://aistudio.google.com/apikey
GEMINI_API_KEY=
