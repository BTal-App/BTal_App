# Firebase Web App config
# Copia este archivo a .env y rellena con los valores reales
# Console Firebase → Project Settings → tu Web App → SDK setup and configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# App Check · reCAPTCHA v3 site key (PUBLIC, va embebido en el bundle).
# Obtener en https://www.google.com/recaptcha/admin/create con el dominio
# btal-app.web.app (+ localhost para dev). Luego registrar el site key en
# Firebase Console > App Check > Apps > tu web app > reCAPTCHA v3.
# Sin esta variable, App Check NO se inicializa y las llamadas pasan sin
# token · solo válido si Firebase Console NO está en modo enforcement.
VITE_RECAPTCHA_V3_SITE_KEY=

# Gemini API key (Fase 6 IA). NO es para el bundle del cliente.
# Solo se usa desde Cloud Functions vía Firebase Functions secrets:
# `firebase functions:secrets:set GEMINI_API_KEY`. Conservada aquí para
# dev local del backend mientras se construye Fase 6. NUNCA committear.
# Obtener en https://aistudio.google.com/apikey
GEMINI_API_KEY=
