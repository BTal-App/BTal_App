# Firebase Web App config
# Copia este archivo a .env y rellena con los valores reales
# Console Firebase → Project Settings → tu Web App → SDK setup and configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# (Opcional) Realtime Database de la app v1, solo para el script de migración
VITE_LEGACY_RTDB_URL=https://plan-muscular-default-rtdb.europe-west1.firebasedatabase.app
