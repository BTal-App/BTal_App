rules_version = '2';

// Rules version: 2026-05-26-monetizacion-blindada.
// Endurecimiento de campos de monetización · cierra el vector que dejaban
// las rules de 2026-05-13 (un user logueado en la app oficial podía
// modificar `plan`/`plan_pro`/`generaciones`/`fecha_expiracion`/
// `fecha_ultima_generacion` desde DevTools porque solo se chequeaba uid).
//
// FILOSOFÍA
//  - Cross-user: bloqueado por `uid == userId` (como siempre).
//  - Campos de uso (profile, preferences, menu, entrenos, compra,
//    suplementos, registroStats, menuFlags, lastActive, etc.): el dueño
//    puede escribirlos libremente.
//  - Campos de monetización (plan, generaciones, plan_pro,
//    fecha_expiracion, fecha_ultima_generacion): el cliente SOLO puede
//    sembrarlos UNA VEZ con valores "free" seguros. Cualquier cambio
//    posterior queda bloqueado. Admin SDK (Stripe webhook +
//    Cloud Functions con tipos `generatePlan` / `setUserPlan`) ignora
//    rules y puede modificarlos libremente.
//  - El cliente NO puede vaciar/borrar estos campos (set sin merge que
//    los omitiera fallaría también: `affectedKeys()` incluye el campo
//    como "afectado" y el predicado de seed inicial pide que el campo
//    no exista en prev, lo que sería falso si ya existía).
//
// Implementación · seed-only via `affectedKeys()`:
//   El campo SOLO se puede escribir si CUMPLE:
//     - El campo NO existía antes (`!(field in resource.data)`)
//     - El nuevo valor es el default seguro (planSafe/genSafe/false/null)
//   Esto cubre exactamente el caso de la migración automática
//   `ensureUserDocumentSchema` (que siembra defaults a docs viejos).
//   Y bloquea cualquier intento de upgrade vía DevTools.
//
// Subcolección /registros/{YYYY-MM-DD}:
//   Sin cambios desde 2026-05-13. uid + regex de fecha en writes,
//   solo uid en delete.

service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────────────────────────────
    // Helpers de monetización
    // ──────────────────────────────────────────────────────────────────

    // Plan free + valores iniciales (los que devuelve defaultPlan()).
    function planSafe(p) {
      return p.tipo == 'free'
        && p.vence_en == null
        && p.one_off_consumido == false;
    }

    // Generaciones con cero consumo (los que devuelve defaultGeneraciones()).
    // `ciclo_inicio` puede ser cualquier número (Date.now al seed) · no se
    // chequea su valor porque el cliente legítimamente lo siembra con un
    // timestamp fresco; lo que importa es que `consumidas_ciclo == 0` y
    // que `menu_at`/`entrenos_at` sigan a null.
    function genSafe(g) {
      return g.menu_at == null
        && g.entrenos_at == null
        && g.consumidas_ciclo == 0;
    }

    // Devuelve true si la escritura NO toca campos de monetización, O si
    // los toca es un seed inicial (el campo no existía antes y el valor
    // nuevo es el default seguro). Cualquier otro caso = bloqueado.
    function monetizationLocked(req, prev) {
      return (
        !req.diff(prev).affectedKeys().hasAny(['plan'])
        || (!('plan' in prev) && planSafe(req.plan))
      ) && (
        !req.diff(prev).affectedKeys().hasAny(['generaciones'])
        || (!('generaciones' in prev) && genSafe(req.generaciones))
      ) && (
        !req.diff(prev).affectedKeys().hasAny(['plan_pro'])
        || (!('plan_pro' in prev) && req.plan_pro == false)
      ) && (
        !req.diff(prev).affectedKeys().hasAny(['fecha_expiracion'])
        || (!('fecha_expiracion' in prev) && req.fecha_expiracion == null)
      ) && (
        !req.diff(prev).affectedKeys().hasAny(['fecha_ultima_generacion'])
        || (!('fecha_ultima_generacion' in prev) && req.fecha_ultima_generacion == null)
      );
    }

    // Para CREATE: si incluye los campos, deben ser valores seguros.
    // No hace falta el check de "no existía antes" porque CREATE solo
    // aplica cuando el doc no existe.
    function monetizationSafeOnCreate(data) {
      return (
        !('plan' in data) || planSafe(data.plan)
      ) && (
        !('generaciones' in data) || genSafe(data.generaciones)
      ) && (
        !('plan_pro' in data) || data.plan_pro == false
      ) && (
        !('fecha_expiracion' in data) || data.fecha_expiracion == null
      ) && (
        !('fecha_ultima_generacion' in data) || data.fecha_ultima_generacion == null
      );
    }

    match /users/{userId} {
      // Lectura: solo el dueño.
      allow read: if request.auth != null && request.auth.uid == userId;

      // Creación: dueño + monetización en valores seguros (free / null / 0).
      // Cubre `saveOnboardingProfile` y `seedGuestDocument` que ya
      // siembran los defaults seguros vía `defaultPlan()`/`defaultGeneraciones()`.
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && monetizationSafeOnCreate(request.resource.data);

      // Actualización: dueño + monetización bloqueada salvo seed inicial.
      //
      // Permite:
      //   - Updates normales (profile, preferences, menu, entrenos,
      //     compra, suplementos, registroStats, lastActive, etc.).
      //   - Migración `ensureUserDocumentSchema` sembrando defaults en
      //     docs viejos (los campos faltantes pasan el check de seed).
      //
      // Bloquea:
      //   - Cliente intentando subirse a Pro (`plan.tipo = 'pro'`).
      //   - Cliente intentando resetear su contador (`consumidas_ciclo = 0`
      //     cuando ya era >0).
      //   - Cliente intentando adelantarse la fecha de expiración.
      //   - Cliente intentando vaciar/borrar estos campos.
      //
      // Stripe webhook + Cloud Functions usan Admin SDK que ignora rules
      // · pueden tocar libremente para flujos legítimos (suscripción Pro,
      // pago único 4,99€, decremento de generaciones consumidas, etc.).
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && monetizationLocked(request.resource.data, resource.data);

      // Borrado: solo el dueño (caso eliminar cuenta).
      allow delete: if request.auth != null && request.auth.uid == userId;

      // Subcolección /registros/{YYYY-MM-DD} · sin cambios.
      //
      // ⚠ NOTA · separamos `create, update` de `delete`. En un delete
      // `request.resource` es null, por lo que cualquier predicado
      // sobre `request.resource.X` evalúa false y bloquearía también
      // los deletes legítimos del botón "Eliminar registro" del
      // RegDayPanel. Por eso el delete tiene solo el check de
      // ownership · el `fecha.matches(...)` solo aplica a writes.
      match /registros/{fecha} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create, update: if request.auth != null
                              && request.auth.uid == userId
                              && fecha.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$');
        allow delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Cualquier otra colección queda bloqueada por defecto.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
